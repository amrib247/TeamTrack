rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Chat attachments: authenticated users only, 10 MB max (matches Chat.tsx)
    match /chat-files/{teamId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024;
    }
  }
}
