rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function hasRequiredKeys(keys) {
      return request.resource.data.keys().hasAll(keys);
    }

    // Profiles: readable when signed in; writable by owner (allows profile creation at register)
    match /userProfiles/{userId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isOwner(userId);
    }

    match /chat_messages/{messageId} {
      allow read: if isVerified();
      allow create: if isVerified()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.teamId is string
        && request.resource.data.content is string;
      allow update: if isVerified()
        && resource.data.userId == request.auth.uid;
      allow delete: if isVerified()
        && resource.data.userId == request.auth.uid;
    }

    match /chat_rooms/{roomId} {
      allow read, write: if isVerified();
    }

    match /availabilities/{availabilityId} {
      allow read: if isVerified();
      allow create: if isVerified()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status in ['YES', 'NO', 'MAYBE'];
      allow update: if isVerified()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid;
      allow delete: if isVerified()
        && resource.data.userId == request.auth.uid;
    }

    match /tasks/{taskId} {
      allow read: if isVerified();
      allow create: if isVerified()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.teamId is string;
      allow update, delete: if isVerified();
    }

    match /organizerTournaments/{orgId} {
      allow read: if isVerified();
      allow create: if isVerified()
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isVerified()
        && resource.data.userId == request.auth.uid;
    }

    match /teams/{teamId} {
      allow read: if isVerified();
      allow create: if isVerified()
        && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if isVerified();
    }

    match /userTeams/{userTeamId} {
      allow read: if isVerified();
      allow create: if isVerified()
        && hasRequiredKeys(['userId', 'teamId', 'role']);
      allow update, delete: if isVerified();
    }

    match /events/{eventId} {
      allow read, write: if isVerified();
    }

    match /tournaments/{tournamentId} {
      allow read, write: if isVerified();
    }

    match /tournamentInvites/{inviteId} {
      allow read, write: if isVerified();
    }
  }
}
